# Configuration de l'API (copier en `.env`, gitignoré).

# DSN PostGIS — REQUIS. Doit pointer vers la base peuplée par les pipelines gold/geo.
API_DATABASE_URL=postgresql://homepedia:changeme-postgres@localhost:5432/homepedia

# Durée de cache HTTP des réponses choroplèthe (secondes).
# API_CACHE_MAX_AGE=3600

# Origines CORS autorisées (JSON). Webapp Vite en dev :
# API_CORS_ORIGINS=["http://localhost:5173"]
# En prod (Cloud Run) :
# API_CORS_ORIGINS=["https://homepedia.example.com"]

# Port d'écoute du conteneur (défaut 8000 ; Cloud Run injecte PORT=8080).
# PORT=8000
